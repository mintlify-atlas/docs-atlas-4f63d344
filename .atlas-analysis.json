  "keyFeatures": [
    "User authentication with JWT and role-based access (admin/seller)",
    "Horse listing management with photos, videos, and location",
    "Advanced marketplace with filtering and search capabilities",
    "Real-time chat system using Socket.io for buyer-seller communication",
    "Seller identity verification system with document upload",
    "Veterinary records tracking for horses",
    "Responsive Next.js frontend with Tailwind CSS",
    "Express.js REST API with MongoDB database",
    "Rate limiting and security middleware (Helmet)",
    "Full-text search for horse listings"
  ],
  "publicApiSurface": [
    "POST /auth/register - Register new user",
    "POST /auth/login - User login",
    "GET /auth/me - Get current user profile",
    "PUT /auth/seller-profile - Update seller verification info",
    "GET /horses - List all horses with filtering",
    "GET /horses/:id - Get single horse details",
    "POST /horses - Create new horse listing",
    "PUT /horses/:id - Update horse listing",
    "DELETE /horses/:id - Delete horse listing",
    "GET /horses/my-listings - Get seller's own horses",
    "POST /horses/:id/vet-record - Add veterinary record",
    "GET /horses/:id/vet-records - Get horse's vet records",
    "GET /chat/conversations - List user's conversations",
    "POST /chat/conversations - Create or get conversation",
    "GET /chat/conversations/:id/messages - Get conversation messages",
    "POST /chat/conversations/:id/messages - Send message",
    "GET /chat/unread-count - Get unread messages count",
    "Socket.io: join_conversation, send_message, typing, stop_typing"
  ]
}
